# Server username that owns the repo and runs the services.
USER=youruser

# Absolute path to the repository root on this machine.
REPO_ROOT=/path/to/repo

# Absolute path to the conda environment bin directory.
CONDA_ENV_BIN=/path/to/conda/envs/bookrec-api/bin

# Absolute path to the secrets/environment file on this machine.
ENV_FILE=/path/to/env

# Public domain name for the nginx vhost.
DOMAIN=yourdomain.example.com

# Absolute path to the nginx document root for static files.
WEBROOT=/var/www/sites/recsys

# Absolute path to the nginx basic-auth password file for Grafana.
GRAFANA_HTPASSWD=/path/to/grafana/password
