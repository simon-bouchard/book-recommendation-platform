        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit",
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(rate(http_requests_total{job=\"bookrec\", status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total{job=\"bookrec\"}[5m]))",
          "instant": true,
          "legendFormat": "Error rate"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
