{
  "title": "BookRec",
  "uid": "bookrec-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "bookrec"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(http_requests_total{job=\"bookrec\"})",
          "instant": true,
          "legendFormat": "Total"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
