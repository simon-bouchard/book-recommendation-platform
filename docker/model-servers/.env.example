# docker/model-servers/env.example
#
# Reference document — do not use this file directly.
#
# Append the variables below to /etc/bookrec.env, which is already used by
# the other docker compose files in this project. The docker-compose.yml for
# the model servers points to the same file via env_file: /etc/bookrec.env.
#
# ARTIFACTS_DIR is the only variable read by docker-compose.yml itself
# (for the volume mount path). All other variables are passed into the
# containers as environment variables.

# ---------------------------------------------------------------------------
# Volume paths (resolved by docker-compose on the host)
# ---------------------------------------------------------------------------

# Absolute path to the models/artifacts directory on the host.
# Bind-mounted read-only into every container at /app/models/artifacts.
ARTIFACTS_DIR=/home/simon/documents/book_recsys/models/artifacts

# ---------------------------------------------------------------------------
# Variables passed into every container
# ---------------------------------------------------------------------------

# Attention strategy used by the embedder server.
# One of: scalar | perdim | selfattn | selfattn_perdim
ATTN_STRATEGY=selfattn

# Number of Gunicorn workers per container.
# With preload + copy-on-write, memory cost does not scale with worker count.
# 2 is sufficient for a single-VM deployment; raise if CPU is underutilised.
GUNICORN_WORKERS=2

# Gunicorn / uvicorn log level.
# One of: debug | info | warning | error | critical
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Main application client URLs
# ---------------------------------------------------------------------------
# These are read by the main application (systemd/gunicorn), not by the model
# server containers themselves. With host networking, localhost resolves
# correctly from both the host and from other containers.

EMBEDDER_URL=http://localhost:8001
SIMILARITY_URL=http://localhost:8002
ALS_URL=http://localhost:8003
METADATA_URL=http://localhost:8004
